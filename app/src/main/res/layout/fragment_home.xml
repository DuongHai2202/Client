<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coffee_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="20dp">

        <!-- Lời chào đầu buổi sáng -->
        <TextView
            android:id="@+id/tvHello"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="16dp"
            android:text="Ngày mới năng lượng nhé,"
            android:textColor="@color/coffee_text_secondary"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tvQuestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="Hôm nay bạn uống gì?"
            android:textColor="@color/coffee_text"
            android:textStyle="bold"
            android:textSize="26sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHello" />

        <!-- Ô Tìm Kiếm (Search Bar) -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="16dp"
            android:background="#D1C4B5"
            android:hint="Tìm kiếm món nước yêu thích..."
            android:textColorHint="#7E6D59"
            android:textColor="@color/coffee_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:drawableEnd="@android:drawable/ic_menu_search"
            android:drawablePadding="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvQuestion" />

        <!-- Tiêu đề Món Yêu Thích (Đã đổi thành Sản phẩm bán chạy) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:text="Sản Phẩm Bán Chạy"
            android:textColor="@color/coffee_text"
            android:textStyle="bold"
            android:textSize="20sp"
            android:id="@+id/tvFeaturedTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/etSearch" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvFeaturedProducts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="8dp"
            android:overScrollMode="never"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/tvFeaturedTitle" />

        <!-- Nút Xem Thêm dẫn vào Menu -->
        <Button
            android:id="@+id/btnSeeMoreMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xem thêm thực đơn"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:backgroundTint="@color/coffee_primary"
            android:layout_marginTop="16dp"
            app:cornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@id/rcvFeaturedProducts"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/pbHomeLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvFeaturedTitle"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
