<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@color/coffee_primary"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="24dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark">

    <androidx.cardview.widget.CardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/imgAdminHeaderAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/user_icon" 
            app:tint="@color/coffee_text"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvAdminHeaderName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quản trị viên"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAdminHeaderEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hệ thống nội bộ"
        android:textColor="#D7CCC8"
        android:textSize="14sp" />

</LinearLayout>
