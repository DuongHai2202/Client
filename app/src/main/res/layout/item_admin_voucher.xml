<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvVoucherCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CODE123"
            android:textColor="#FF5722"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVoucherStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Hoạt động"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVoucherDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVoucherCode"
            android:layout_marginTop="4dp"
            android:text="Giảm: 20,000 đ"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvVoucherConditions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVoucherDiscount"
            android:layout_marginTop="4dp"
            android:text="Đơn tối thiểu: 50,000 đ | Còn: 5"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvVoucherConditions"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnEditVoucher"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Sửa"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnDeleteVoucher"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#E53935"
                android:text="Xóa"
                android:textSize="12sp" />
        </LinearLayout>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
