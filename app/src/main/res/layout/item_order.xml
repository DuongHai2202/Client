<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Mã đơn + Trạng thái -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="#ORD001"
                android:textColor="#4E342E"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvOrderStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ xác nhận"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/quantity_box_bg"
                android:textColor="#FF6F00" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#E0E0E0" />

        <!-- Thanh trạng thái tiến trình dạng bước (Kiểu Shopee) -->
        <LinearLayout
            android:id="@+id/llStatusSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Bước 1: Chờ xác nhận -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/dotPending"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/status_dot_inactive" />
                <TextView
                    android:id="@+id/tvStepPending"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chờ"
                    android:textSize="9sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:id="@+id/linePendingConfirmed"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="2dp"
                android:background="#E0E0E0" />

            <!-- Bước 2: Xác nhận -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/dotConfirmed"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/status_dot_inactive" />
                <TextView
                    android:id="@+id/tvStepConfirmed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác nhận"
                    android:textSize="9sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:id="@+id/lineConfirmedPreparing"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="2dp"
                android:background="#E0E0E0" />

            <!-- Bước 3: Pha chế -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/dotPreparing"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/status_dot_inactive" />
                <TextView
                    android:id="@+id/tvStepPreparing"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pha chế"
                    android:textSize="9sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:id="@+id/linePreparingShipping"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="2dp"
                android:background="#E0E0E0" />

            <!-- Bước 4: Giao hàng -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/dotShipping"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/status_dot_inactive" />
                <TextView
                    android:id="@+id/tvStepShipping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giao"
                    android:textSize="9sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <View
                android:id="@+id/lineShippingCompleted"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="2dp"
                android:background="#E0E0E0" />

            <!-- Bước 5: Hoàn thành -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/dotCompleted"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/status_dot_inactive" />
                <TextView
                    android:id="@+id/tvStepCompleted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xong"
                    android:textSize="9sp"
                    android:textColor="#BDBDBD"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Danh sách sản phẩm tóm tắt -->
        <TextView
            android:id="@+id/tvOrderItemsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cà Phê Sữa Đá x2, Trà Đào x1"
            android:textColor="#5D4037"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvOrderDate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="14/04/2026 10:30"
                android:textColor="#8D6E63"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85,000 đ"
                android:textColor="#D84315"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
